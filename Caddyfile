# global options
{
    admin off
    persist_config off
    auto_https off
    log {
        format json
    }
    servers {
        trusted_proxies static private_ranges 100.0.0.0/8
    }
}

# site block — Railway assigns $PORT automatically
:{$PORT:3000} {
    log {
        format json
    }

    # health check
    rewrite /health /*

    # serve from the dist folder (Vite output)
    root * dist

    # gzip
    encode gzip

    file_server

    # SPA fallback — redirect unknown paths to index.html
    try_files {path} /index.html
}
